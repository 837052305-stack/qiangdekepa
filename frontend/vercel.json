{               
    "version": 2,                                                                                                       
    "name": "qiangdekepa",
    "framework": "create-react-app",                                                                                    
    "routes": [                                                                                                         
      {                                                                                                                 
        "src": "/static/(.*)",                                                                                          
        "headers": {                                                                                                    
          "cache-control": "s-maxage=31536000,immutable"                                                                
        }                                                                                                               
      },                                                                                                                
      {                                                                                                                 
        "src": "/(.*)",                                                                                                 
        "dest": "/index.html"                                                                                           
      }                                                                                                                 
    ]                                                                                                                   
  }            
