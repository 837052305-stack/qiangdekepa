# ==========================================
# 邮件配置 (用于密码找回功能)
# 支持：Gmail、QQ邮箱、163邮箱、126邮箱、SendGrid 等
# 系统会根据邮箱后缀自动识别服务商
# ==========================================

# 发件人邮箱地址 (必填)
EMAIL_USER=your-email@gmail.com

# 邮箱授权码/密码 (必填)
# - Gmail: 使用应用专用密码 (需开启两步验证)
# - QQ邮箱: 使用授权码 (在邮箱设置-账户-生成授权码)
# - 163邮箱: 使用授权码 (在邮箱设置-POP3/SMTP-客户端授权码)
EMAIL_PASS=your-password-or-app-specific-password

# 前端地址 (重置密码链接会指向这个地址)
FRONTEND_URL=https://qiangdekepa.vercel.app

# 可选：指定邮件服务商 (如果不填，系统会自动根据邮箱后缀识别)
# 可选值: gmail, qq, 163, sendgrid, outlook 等
# EMAIL_SERVICE=gmail
